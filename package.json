{
	"name": "@fgiova/mini-dynamo-mapper",
	"version": "1.0.0",
	"main": "./dist/cjs/index.js",
	"types": "./dist/cjs/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/esm/index.d.mts",
				"default": "./dist/esm/index.mjs"
			},
			"require": {
				"types": "./dist/cjs/index.d.ts",
				"default": "./dist/cjs/index.js"
			}
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"clean": "rimraf dist",
		"preBuild": "npm run clean",
		"build": "esmBuilder",
		"lint": "biome ci ./src ./test",
		"fix": "biome check --write ./src ./test",
		"test": "tap",
		"test:integration": "tap test/integration/*.ts",
		"test:debug": "tap --only --timeout=0",
		"test:coverage": "tap --coverage-report=lcovonly --coverage-report=text test/unit/*.ts",
		"test:local": "TEST_LOCAL=true tap test/integration/*.ts"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fgiova/mini-dynamo-mapper.git"
	},
	"author": "Francesco Giovannini <fgiova@fgiova.com>",
	"license": "MIT",
	"keywords": [
		"aws",
		"dynamodb",
		"dynamo-mapper",
		"orm"
	],
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": "^22.14.0 || >= 24.10.0"
	},
	"tap": {
		"show-full-coverage": true,
		"before": "./test/scripts/executors/before.js",
		"after": "./test/scripts/executors/teardown.js",
		"exclude": [
			"test/helpers/**/*",
			"test/scripts/**/*"
		]
	},
	"dependencies": {
		"@fgiova/mini-dynamo-client": "^1.0.0"
	},
	"devDependencies": {
		"@aws-sdk/client-dynamodb": "^3.758.0",
		"@biomejs/biome": "2.2.2",
		"@fgiova/aws-signature": "^4.0.0",
		"@fgiova/cjs-esm-ts-builder": "^1.2.0",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/npm": "^13.1.4",
		"@tsconfig/node22": "^22.0.5",
		"@types/node": "^22.19.11",
		"conventional-changelog-conventionalcommits": "^9.1.0",
		"dotenv": "^17.2.4",
		"semantic-release": "^25.0.3",
		"tap": "^21.1.0",
		"testcontainers": "^11.11.0",
		"typescript": "^5.8.2",
		"undici": "^7.22.0"
	}
}
